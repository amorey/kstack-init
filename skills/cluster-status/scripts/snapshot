#!/usr/bin/env bash
# cluster-status/scripts/snapshot — deterministic health snapshot of the
# cluster covering nodes, pods, workloads, and PDBs.
#
# Invoked by the /cluster-status skill body with $KSTACK_ROOT pointing at
# the install root (repo-local: <repo>/.kstack; global: ~/.config/kstack).
# Owns its own flag parsing; the skill body forwards "$@" verbatim. The
# script never mutates cluster state.

set -eu

# usage: print the short invocation summary to stderr.
usage() {
  cat >&2 <<'EOF'
Usage: snapshot [--context <c>] [--namespace <n>] [--json] [--dry-run]
                [--since <5m|1h|24h>] [--severity <critical|warning|info>]
EOF
}

# Sourceability guard: when the file is sourced for unit tests, skip main.
main() {
  : "${KSTACK_ROOT:?KSTACK_ROOT must be set — invoke via the /cluster-status skill}"
  LIB_DIR="$KSTACK_ROOT/lib/cluster-status"
  # shellcheck source=/dev/null
  . "$LIB_DIR/helpers.sh"
  # shellcheck source=/dev/null
  . "$LIB_DIR/fetch.sh"

  CONTEXT=""
  NAMESPACE=""
  JSON=0
  DRY_RUN=0
  SINCE_SECS=0
  SEVERITY=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --context) [ -z "${2:-}" ] && { echo "Missing value for --context" >&2; exit 2; }
                 CONTEXT="$2"; shift 2 ;;
      --context=*) CONTEXT="${1#--context=}"; shift ;;
      --namespace|-n) [ -z "${2:-}" ] && { echo "Missing value for --namespace" >&2; exit 2; }
                 NAMESPACE="$2"; shift 2 ;;
      --namespace=*) NAMESPACE="${1#--namespace=}"; shift ;;
      --json) JSON=1; shift ;;
      --dry-run) DRY_RUN=1; shift ;;
      --since) [ -z "${2:-}" ] && { echo "Missing value for --since" >&2; exit 2; }
               SINCE_SECS="$(parse_duration_to_secs "$2")" || exit 2
               shift 2 ;;
      --since=*) SINCE_SECS="$(parse_duration_to_secs "${1#--since=}")" || exit 2
                 shift ;;
      --severity) [ -z "${2:-}" ] && { echo "Missing value for --severity" >&2; exit 2; }
                  validate_severity "$2" || exit 2
                  SEVERITY="$2"; shift 2 ;;
      --severity=*) validate_severity "${1#--severity=}" || exit 2
                    SEVERITY="${1#--severity=}"; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown flag '$1'" >&2; usage; exit 2 ;;
    esac
  done

  if [ "$DRY_RUN" -eq 1 ]; then
    local cluster_args namespaced_args
    cluster_args="$(build_kubectl_args "$CONTEXT" "" cluster)"
    namespaced_args="$(build_kubectl_args "$CONTEXT" "$NAMESPACE" namespaced)"
    echo "# would run: kubectl get nodes $cluster_args -o json"
    echo "# would run: kubectl get pods $namespaced_args -o json"
    echo "# would run: kubectl get deployments,statefulsets,daemonsets $namespaced_args -o json"
    echo "# would run: kubectl get poddisruptionbudgets $namespaced_args -o json"
    echo "Dry run — no commands executed."
    return 0
  fi

  TMP="$(mktemp -d "${TMPDIR:-/tmp}/kstack-cluster-status.XXXXXX")"
  trap 'rm -rf "$TMP"' EXIT INT TERM

  fetch_all "$TMP" "$CONTEXT" "$NAMESPACE"
  record_errors "$TMP" "$TMP/errors.json"

  local mode="prose"
  [ "$JSON" -eq 1 ] && mode="json"
  local now
  now="${KSTACK_NOW:-$(date -u +%Y-%m-%dT%H:%M:%SZ)}"

  local jq_raw_flag="-nr"
  [ "$mode" = "json" ] && jq_raw_flag="-n"

  local jq_out rc=0
  jq_out="$(jq -L "$LIB_DIR" $jq_raw_flag \
    --slurpfile nodes     "$TMP/nodes.json" \
    --slurpfile pods      "$TMP/pods.json" \
    --slurpfile workloads "$TMP/workloads.json" \
    --slurpfile pdbs      "$TMP/pdbs.json" \
    --slurpfile errs      "$TMP/errors.json" \
    --arg      context    "$CONTEXT" \
    --arg      namespace  "$NAMESPACE" \
    --arg      severity   "$SEVERITY" \
    --arg      now        "$now" \
    --argjson  since_secs "$SINCE_SECS" \
    --arg      mode       "$mode" \
    -f "$LIB_DIR/aggregate.jq")" || rc=$?

  if [ "$rc" -ne 0 ]; then
    echo "aggregate.jq failed (rc=$rc)" >&2
    return 1
  fi
  printf '%s\n' "$jq_out"
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
