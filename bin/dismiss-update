#!/usr/bin/env bash
# kstack dismiss-update — silence the current update notice until a newer release.
#
# Writes dismissed_version = latest_known in the local cache. The next time an
# upstream release bumps latest_known above the dismissed value, the notice
# returns automatically.
#
# Exits silently when there's nothing to dismiss (no cache, no known release).

set -u

main() {
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

  if [ "$SCRIPT_DIR" = "$HOME/.config/kstack/bin" ]; then
    INSTALL_ROOT="$HOME/.config/kstack"
    CACHE_DIR="$INSTALL_ROOT/cache"
  else
    INSTALL_ROOT="$(dirname "$SCRIPT_DIR")"
    CACHE_DIR="$INSTALL_ROOT/.cache/kstack"
  fi

  CACHE_FILE="$CACHE_DIR/update.json"

  if [ ! -f "$CACHE_FILE" ]; then
    echo "Nothing to dismiss — no update check has run yet."
    exit 0
  fi

  cache_ts="$(sed -n 's/.*"last_check"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CACHE_FILE" | head -1)"
  cache_latest="$(sed -n 's/.*"latest_known"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CACHE_FILE" | head -1)"

  if [ -z "$cache_latest" ]; then
    echo "Nothing to dismiss — no known available release."
    exit 0
  fi

  now_iso="${cache_ts:-$(date -u +"%Y-%m-%dT%H:%M:%SZ")}"

  cat > "$CACHE_FILE.tmp" <<EOF
{
  "last_check": "$now_iso",
  "latest_known": "$cache_latest",
  "dismissed_version": "$cache_latest"
}
EOF
  mv "$CACHE_FILE.tmp" "$CACHE_FILE"

  echo "Dismissed update notice for kstack $cache_latest. You'll be notified again when a newer release is published."
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
