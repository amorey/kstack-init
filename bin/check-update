#!/usr/bin/env bash
# kstack check-update — cached check for a newer kstack release.
#
# Invoked by agents (Claude, etc.) from skill preambles via {{BIN_DIR}}/check-update.
# Never fails — offline, missing deps, or unknown state all exit silently so a
# failing check cannot break skill invocation.
#
# Usage:
#   check-update              Print notice, or "up to date" when no notice is due.
#   check-update --quiet      Print only if a notice is due; silent otherwise.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/cache.sh
. "$SCRIPT_DIR/../lib/cache.sh"

REMOTE_URL="${KSTACK_REMOTE_URL:-https://github.com/kubetail-org/kstack.git}"
TTL_SECS=$((24 * 60 * 60))

bail() { exit 0; }

# is_newer $a $b → exit 0 if $a > $b via semver sort.
is_newer() {
  [ "$1" = "$2" ] && return 1
  local top
  top=$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)
  [ "$top" = "$1" ] && return 0 || return 1
}

iso_to_epoch() {
  case "$OSTYPE" in
    darwin*|bsd*) date -j -f "%Y-%m-%dT%H:%M:%SZ" "$1" +%s 2>/dev/null || echo 0 ;;
    *)            date -d "$1" +%s 2>/dev/null || echo 0 ;;
  esac
}

main() {
  local QUIET=0
  case "${1:-}" in
    --quiet|-q) QUIET=1 ;;
  esac

  resolve_cache_paths "$SCRIPT_DIR"

  local INSTALLED=""
  if [ "$SCRIPT_DIR" = "$HOME/.config/kstack/bin" ]; then
    [ -f "$INSTALL_ROOT/install.conf" ] && read -r INSTALLED < "$INSTALL_ROOT/install.conf" 2>/dev/null
  else
    local origin_url
    origin_url="$(git -C "$INSTALL_ROOT" config --get remote.origin.url 2>/dev/null)"
    case "$origin_url" in
      *kubetail-org/kstack.git|*kubetail-org/kstack) ;;
      *) bail ;;
    esac
    INSTALLED="$(git -C "$INSTALL_ROOT" describe --tags --exact-match HEAD 2>/dev/null)"
  fi

  case "$INSTALLED" in
    ""|main) bail ;;
  esac

  mkdir -p "$CACHE_DIR" 2>/dev/null || true

  local cache_ts cache_latest cache_dismissed
  read_cache_fields "$CACHE_FILE"

  local now_epoch cache_epoch=0 age LATEST="$cache_latest"
  now_epoch=$(date +%s)
  [ -n "$cache_ts" ] && cache_epoch=$(iso_to_epoch "$cache_ts")
  age=$((now_epoch - cache_epoch))

  if [ -z "$LATEST" ] || [ "$age" -ge "$TTL_SECS" ] || [ "$age" -lt 0 ]; then
    local fresh
    fresh=$(git ls-remote --tags "$REMOTE_URL" 'v*' 2>/dev/null \
      | awk -F'refs/tags/' '/refs\/tags\/v[0-9]/ && !/\^\{\}$/ { print $2 }' \
      | sort -V | tail -1)
    if [ -n "$fresh" ]; then
      LATEST="$fresh"
      write_cache_json "$CACHE_FILE" \
        "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
        "$LATEST" \
        "$cache_dismissed"
    fi
  fi

  [ -z "$LATEST" ] && bail

  if is_newer "$LATEST" "$INSTALLED"; then
    if [ -n "$cache_dismissed" ] && ! is_newer "$LATEST" "$cache_dismissed"; then
      [ "$QUIET" -eq 1 ] || echo "kstack $INSTALLED is up to date (update to $LATEST dismissed)."
      bail
    fi
    echo "kstack $LATEST is available (you're on $INSTALLED). Say \"upgrade kstack\" to install, or \"dismiss\" to hide until the next release."
  else
    [ "$QUIET" -eq 1 ] || echo "kstack $INSTALLED is up to date."
  fi
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
