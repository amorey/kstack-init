#!/usr/bin/env bash
# kstack uninstall — remove the global kstack install.
#
# This script only handles the global install. The canonical way to invoke
# it is via the copy bundled at:
#
#   ~/.config/kstack/bin/uninstall
#
# To remove a repo-local install, just delete the kstack repo directory —
# the local install renders skills directly into <repo>/.<agent>/skills/
# and never writes outside the repo.
#
# Usage:
#   uninstall              Interactive — prompts before removing.
#   uninstall --force      Skip the confirmation prompt.
#   uninstall --agent <n>  Scope to one agent.
#
# What gets removed:
#   ~/.claude/skills/kstack-*/   (and equivalents for every supported agent)
#   ~/.config/kstack/            (bin helpers + anything else kstack owns)
#
# Uses `set -uo pipefail` (no -e) so uninstall never aborts partway.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/agents.sh
. "$SCRIPT_DIR/../lib/agents.sh"

main() {
  if [ -z "${HOME:-}" ]; then
    echo "ERROR: \$HOME is not set" >&2
    exit 1
  fi

  local KSTACK_CONFIG_DIR="$HOME/.config/kstack"

  if [ "$SCRIPT_DIR" != "$KSTACK_CONFIG_DIR/bin" ]; then
    echo "This is the global uninstaller — run it from $KSTACK_CONFIG_DIR/bin/" >&2
    echo "to remove the global install." >&2
    echo >&2
    echo "To remove a repo-local install, just delete the kstack repo directory." >&2
    exit 1
  fi

  local FORCE=0 AGENT=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) FORCE=1; shift ;;
      --agent)
        [ -z "${2:-}" ] && { echo "Missing value for --agent" >&2; exit 1; }
        AGENT="$2"; shift 2 ;;
      --agent=*) AGENT="${1#--agent=}"; shift ;;
      -h|--help)
        sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
        exit 0 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local TARGET_AGENTS
  if [ -z "$AGENT" ]; then
    TARGET_AGENTS="$KNOWN_AGENTS"
  elif is_known_agent "$AGENT"; then
    TARGET_AGENTS="$AGENT"
  else
    echo "Unknown agent: $AGENT" >&2
    echo "Supported: $KNOWN_AGENTS" >&2
    exit 1
  fi

  # Collect every path that would be removed so preview and deletion iterate
  # the same list.
  local ENTRIES=() skills_dir h entry
  for h in $TARGET_AGENTS; do
    skills_dir="$(agent_skills_dir_global "$h")"
    [ -d "$skills_dir" ] || continue
    for entry in "$skills_dir"/kstack-*; do
      [ -e "$entry" ] || [ -L "$entry" ] || continue
      ENTRIES+=("$entry")
    done
  done
  [ -d "$KSTACK_CONFIG_DIR" ] && ENTRIES+=("$KSTACK_CONFIG_DIR")

  if [ ${#ENTRIES[@]} -eq 0 ]; then
    echo "Nothing to remove — kstack is not installed."
    exit 0
  fi

  if [ "$FORCE" -eq 0 ]; then
    echo "This will remove:"
    printf '  %s\n' "${ENTRIES[@]}"
    printf "\nContinue? [y/N] "
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi

  local removed=""
  for entry in "${ENTRIES[@]}"; do
    rm -rf "$entry"
    removed="$removed ${entry#$HOME/}"
  done

  echo "Removed:$removed"
  echo "kstack uninstalled."
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
