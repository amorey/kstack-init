# Repo-local install artifacts (generated by `./setup`; specific to the
# checking-out user's path, never committed).
/.claude
/.codex
/.config/opencode
/.cursor
/.factory
/.slate
/.kiro
/.hermes

# Repo-local kstack state (update-check cache, learned state).
/.kstack/

# Eval harness artifacts (transcripts, judge outputs, state snapshots).
/tests/evals/artifacts/*
!/tests/evals/artifacts/.gitkeep

# Misc
.DS_STORE
