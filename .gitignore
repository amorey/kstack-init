# Dev-mode install artifacts (generated by `./install` from a checkout;
# specific to the contributor's path, never committed).
/.claude
/.codex
/.config/opencode
/.cursor
/.factory
/.slate
/.kiro
/.hermes

# Dev-mode kstack state (update-check cache, learned state).
/.kstack/

# Eval harness artifacts (transcripts, judge outputs, state snapshots).
/tests/evals/artifacts/*
!/tests/evals/artifacts/.gitkeep

# Misc
.DS_STORE
.worktrees
