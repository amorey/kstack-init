#!/usr/bin/env bash
# kstack install (wrapper) — delegates to src/install.
#
# The repo root stays deliberately minimal for end users; all source lives
# under src/. For the full flag reference, run `./install --help`.
set -eu
DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
exec "$DIR/src/install" "$@"
