#!/usr/bin/env bash
# kstack install — install kstack skills for one or more AI agents.
#
# This script lives at <repo>/src/install. Users invoke it via the thin
# wrapper at <repo>/install, which just execs this file with the same args.
#
# Two install modes:
#
#   Repo-local (default) — for the `cd kstack && claude` flow.
#     Renders each src/skills/<skill>/SKILL.md.tmpl directly into
#     <repo>/.<agent>/skills/<skill>/SKILL.md. Skills are discovered
#     from the repo when the agent is invoked from inside it.
#
#   Global (--global) — for ambient use outside the repo.
#     Maintains a kstack-owned checkout at ~/.config/kstack/upstream/ at
#     the latest released tag, then renders skills from there into
#     ~/.<agent>/skills/kstack-<skill>/SKILL.md and copies helper binaries
#     into ~/.config/kstack/bin/. The invoker's checkout is never used
#     as the source in global mode — the canonical upstream is cloned
#     fresh so running `./install --global` from a fork cannot silently
#     install the fork's contents.
#
# Upgrade:
#     Repo-local: `git pull && ./install`
#     Global:     `~/.config/kstack/bin/upgrade` (wrapper that re-runs
#                 this script at the latest tag — see below).
#
# Usage:
#   ./install                        Repo-local, auto-detect agents (falls back to claude).
#   ./install --agent <name>         Limit to one agent.
#   ./install --global               Global install for auto-detected agents.
#   ./install --global --agent <n>   Global install, one agent.
#   ./install -q | --quiet           Suppress log output.
#
# Supported agents: claude, codex, opencode, cursor, factory, slate, kiro, hermes

set -eu

# SCRIPT_DIR is <repo>/src. The parent (<repo>) is computed inside main() as
# CHECKOUT_ROOT in repo-local mode; install outputs (.kstack/, .<agent>/skills/)
# land there so end users see skills when they run their agent from the repo
# root, not from inside src/.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=lib/agents.sh
. "$SCRIPT_DIR/lib/agents.sh"

KSTACK_CONFIG_DIR="$HOME/.config/kstack"
# Global-mode clone target. Named "upstream" (not "src") because the cloned
# repo carries its own src/ subdir; SRC_ROOT in global mode is $KSTACK_UPSTREAM/src.
# ensure_src_checkout migrates legacy $KSTACK_CONFIG_DIR/src layouts on first run.
KSTACK_UPSTREAM="$KSTACK_CONFIG_DIR/upstream"
# Override KSTACK_REMOTE_URL for CI and local-clone testing. Leave unset for
# normal user installs.
KSTACK_REMOTE_URL="${KSTACK_REMOTE_URL:-https://github.com/kubetail-org/kstack.git}"

QUIET=0
log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# write_install_conf $root $version
write_install_conf() { printf '%s\n' "$2" > "$1/install.conf"; }

# Clones (first time) or fetches+checks-out (subsequent runs) the canonical
# upstream at the latest tagged release. Pre-release fallback: if no `v*` tags
# exist anywhere, use `main` with a visible warning.
ensure_src_checkout() {
  mkdir -p "$KSTACK_CONFIG_DIR"
  # Migrate the legacy clone target ($KSTACK_CONFIG_DIR/src) to the new
  # $KSTACK_UPSTREAM location. The old target collided with the repo's own
  # src/ subdir after the source restructure; existing global installs
  # self-heal on their next upgrade.
  if [ -d "$KSTACK_CONFIG_DIR/src/.git" ] && [ ! -d "$KSTACK_UPSTREAM/.git" ]; then
    log "Migrating legacy checkout $KSTACK_CONFIG_DIR/src → $KSTACK_UPSTREAM"
    rm -rf "$KSTACK_CONFIG_DIR/src"
  fi
  local tag
  if [ -d "$KSTACK_UPSTREAM/.git" ]; then
    log "Updating $KSTACK_UPSTREAM"
    git -C "$KSTACK_UPSTREAM" fetch --tags --quiet origin
    tag="$(git -C "$KSTACK_UPSTREAM" tag -l 'v*' --sort=-v:refname | head -1)"
    if [ -n "$tag" ]; then
      git -C "$KSTACK_UPSTREAM" checkout --quiet "$tag"
      log "  checked out $tag"
    else
      log "  no tagged release found; tracking main"
      git -C "$KSTACK_UPSTREAM" checkout --quiet main
      git -C "$KSTACK_UPSTREAM" pull --ff-only --quiet origin main
      tag="main"
    fi
  else
    tag="$(git ls-remote --tags "$KSTACK_REMOTE_URL" 'v*' 2>/dev/null \
      | awk -F'refs/tags/' '/refs\/tags\/v[0-9]/ && !/\^\{\}$/ { print $2 }' \
      | sort -V | tail -1)"
    if [ -n "$tag" ]; then
      log "Cloning kstack @ $tag into $KSTACK_UPSTREAM"
      git clone --depth 1 --branch "$tag" --quiet "$KSTACK_REMOTE_URL" "$KSTACK_UPSTREAM"
    else
      log "No tagged release found; cloning main into $KSTACK_UPSTREAM"
      git clone --depth 1 --branch main --quiet "$KSTACK_REMOTE_URL" "$KSTACK_UPSTREAM"
      tag="main"
    fi
  fi
  write_install_conf "$KSTACK_CONFIG_DIR" "$tag"
}

# render_skill $skill $agent $root_dir $skill_dir $out_file $skills_src $global_flags_partial $update_check_partial
render_skill() {
  local skill="$1" agent="$2" root_dir="$3" skill_dir="$4" out_file="$5"
  local skills_src="$6" gf="$7" uc="$8"
  mkdir -p "$(dirname "$out_file")"
  awk -v gf="$gf" -v uc="$uc" \
      -v root_dir="$root_dir" \
      -v skill_dir="$skill_dir" \
      -v skill="$skill" -v agent="$agent" '
    function subst(s) {
      gsub(/\{\{ROOT_DIR\}\}/,     root_dir,  s)
      gsub(/\{\{SKILL_DIR\}\}/,    skill_dir, s)
      gsub(/\{\{SKILL_NAME\}\}/,   skill,     s)
      gsub(/\{\{AGENT\}\}/,        agent,     s)
      return s
    }
    function inline(path,    line) {
      while ((getline line < path) > 0) print subst(line)
      close(path)
    }
    /\{\{GLOBAL_FLAGS\}\}/ { inline(gf); next }
    /\{\{UPDATE_CHECK\}\}/ { inline(uc); next }
    { print subst($0) }
  ' "$skills_src/$skill/SKILL.md.tmpl" > "$out_file"
}

# render_help $skill $readme $out_file
#
# Renders a help page for $skill by extracting its <dt>/<dd> block from
# $readme and appending the global-flags table. Exits non-zero if no
# matching section is found. The output ends with the literal sentinel
# "=== END HELP ===" which the skill body uses to detect end-of-help.
render_help() {
  local skill="$1" readme="$2" out_file="$3"
  mkdir -p "$(dirname "$out_file")"

  awk -v skill="$skill" '
    BEGIN { found = 0; in_skill = 0; in_body = 0; in_flags = 0 }

    # Skill body: capture lines between <dd> and </dd> under the target heading.
    $0 ~ "^#### `/" skill "(`| )" {
      found = 1
      in_skill = 1
      body = body "# /" skill "\n\n"
      next
    }
    in_skill && /^<dd>$/ { in_body = 1; next }
    in_body && /^<\/dd>$/ { in_body = 0; in_skill = 0; next }
    in_body { body = body $0 "\n"; next }

    # Global flags: from "**Global flags**" line to the next horizontal rule.
    /^\*\*Global flags\*\*/ { in_flags = 1 }
    in_flags && /^---$/ { in_flags = 0; next }
    in_flags { flags = flags $0 "\n" }

    END {
      if (!found) {
        print "render_help: no README section for /" skill > "/dev/stderr"
        exit 2
      }
      printf "%s\n%s\n=== END HELP ===\n", body, flags
    }
  ' "$readme" > "$out_file" || {
    local rc=$?
    rm -f "$out_file"
    return "$rc"
  }
}

# prune_orphans $target_dir $glob $keep $label
#   Remove any child of $target_dir matching $glob whose basename is not in
#   $keep (space-delimited). Logs each removal as "    pruned: ${label}<basename>".
#   No-op if $target_dir is missing or the glob matches nothing.
prune_orphans() {
  local dir="$1" glob="$2" keep="$3" label="$4"
  [ -d "$dir" ] || return 0
  local entry base
  for entry in "$dir"/$glob; do
    [ -e "$entry" ] || continue
    base="${entry%/}"; base="${base##*/}"
    case " $keep " in
      *" $base "*) continue ;;
    esac
    rm -rf "$entry"
    log "    pruned: ${label}${base}"
  done
}

# install_agent $mode $agent $root_dir $skills_dir $slot_prefix
#   $mode is "local" or "global" — used for log text only.
#   $slot_prefix is "" for local, "kstack-" for global.
install_agent() {
  local mode="$1" agent="$2" root_dir="$3" skills_dir="$4" slot_prefix="$5"
  mkdir -p "$skills_dir"

  local slots="" skill slot out_dir out_file help_file
  for skill in $SKILL_NAMES; do
    slot="${slot_prefix}${skill}"
    out_dir="$skills_dir/$slot"
    out_file="$out_dir/SKILL.md"
    help_file="$out_dir/references/help.md"
    # Clear stale symlinks / non-dirs left by a previous install before re-rendering.
    if [ -L "$out_dir" ] || { [ -e "$out_dir" ] && [ ! -d "$out_dir" ]; }; then
      rm -f "$out_dir"
    fi
    [ -L "$out_file" ] && rm -f "$out_file"
    [ -L "$help_file" ] && rm -f "$help_file"
    mkdir -p "$out_dir"
    render_skill "$skill" "$agent" "$root_dir" "$out_dir" "$out_file" \
      "$SKILLS_SRC" "$GLOBAL_FLAGS_PARTIAL" "$UPDATE_CHECK_PARTIAL"
    render_help "$skill" "$CHECKOUT_ROOT/README.md" "$help_file"
    copy_skill_scripts "$SKILLS_SRC/$skill/scripts" "$out_dir/scripts"
    slots="$slots $slot"
  done

  log "  $agent ($mode) → $skills_dir"
  log "    installed:$slots"

  # Prune stale slots from prior installs. When slot_prefix is "kstack-", the
  # glob scopes pruning to kstack-* so user-owned skills in a shared skills
  # dir are never touched; when empty (repo-local), the glob is "*" and the
  # whole install-owned dir is fair game.
  prune_orphans "$skills_dir" "${slot_prefix}*" "${slots# }" ""
}

# sync_dir $src $glob $dst $label $executable
#   Copies $src/$glob → $dst/, then prunes any $glob-matching orphan in $dst.
#   Skips .gitkeep placeholders. $executable=1 chmods each copy +x.
sync_dir() {
  local src="$1" glob="$2" dst="$3" label="$4" executable="$5"
  mkdir -p "$dst"
  local f name keep=""
  for f in "$src"/$glob; do
    [ -e "$f" ] || continue
    name="${f##*/}"
    [ "$name" = ".gitkeep" ] && continue
    cp "$f" "$dst/"
    [ "$executable" = 1 ] && chmod +x "$dst/$name"
    keep="$keep $name"
  done
  log "  $label → $dst"
  prune_orphans "$dst" "$glob" "${keep# }" "$label"
}

# copy_bin $src $dst
#   Materialize every file in $src/ into $dst/ as an executable helper.
copy_bin() { sync_dir "$1" '*' "$2" "bin/" 1; }

# copy_skill_scripts $src $dst
#   Mirror a skill's scripts/ dir into the rendered slot as executable files.
#   Removes $dst if $src is absent so the slot matches the source.
copy_skill_scripts() {
  local src="$1" dst="$2"
  if [ -d "$src" ]; then
    sync_dir "$src" '*' "$dst" "scripts/" 1
  else
    rm -rf "$dst"
  fi
}

# copy_lib $src $dst — sync lib/*.sh and each lib/<subdir>/ (per-skill helpers).
copy_lib() {
  local src="$1" dst="$2" d name keep=""
  sync_dir "$src" '*.sh' "$dst" "lib/" 0
  for d in "$src"/*/; do
    [ -d "$d" ] || continue
    name="${d%/}"; name="${name##*/}"
    rm -rf "${dst:?}/$name"
    cp -R "$d" "$dst/$name"
    log "  lib/$name/ → $dst/$name"
    keep="$keep $name"
  done
  prune_orphans "$dst" '*/' "${keep# }" "lib/"
}

# write_local_install_conf $root $src — record tag or branch; empty on detached HEAD.
write_local_install_conf() {
  local version
  version="$(git -C "$2" describe --tags --exact-match HEAD 2>/dev/null \
          || git -C "$2" rev-parse --abbrev-ref HEAD 2>/dev/null \
          || true)"
  [ "$version" = "HEAD" ] && version=""
  write_install_conf "$1" "$version"
}

main() {
  AGENT=""
  GLOBAL=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent)
        [ -z "${2:-}" ] && { echo "Missing value for --agent" >&2; exit 1; }
        AGENT="$2"; shift 2 ;;
      --agent=*) AGENT="${1#--agent=}"; shift ;;
      --global) GLOBAL=1; shift ;;
      -q|--quiet) QUIET=1; shift ;;
      -h|--help)
        sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
        exit 0 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  TARGET_AGENTS=""
  if [ -z "$AGENT" ]; then
    for h in $KNOWN_AGENTS; do
      if command -v "$(agent_cli "$h")" >/dev/null 2>&1; then
        TARGET_AGENTS="$TARGET_AGENTS $h"
      fi
    done
    if [ -z "$TARGET_AGENTS" ]; then
      log "No agent CLIs detected on PATH — installing for claude by default."
      TARGET_AGENTS="claude"
    fi
  else
    if ! is_known_agent "$AGENT"; then
      echo "Unknown agent: $AGENT" >&2
      echo "Supported: $KNOWN_AGENTS" >&2
      exit 1
    fi
    TARGET_AGENTS="$AGENT"
  fi
  TARGET_AGENTS="${TARGET_AGENTS# }"

  # CHECKOUT_ROOT is the top of the source checkout (holds README.md and the
  # src/ subdir). SRC_ROOT is the src/ subdir itself (holds skills/, lib/, bin/).
  if [ "$GLOBAL" -eq 1 ]; then
    ensure_src_checkout
    CHECKOUT_ROOT="$KSTACK_UPSTREAM"
    SRC_ROOT="$KSTACK_UPSTREAM/src"
    ROOT_DIR="$KSTACK_CONFIG_DIR"
  else
    CHECKOUT_ROOT="$(dirname "$SCRIPT_DIR")"
    SRC_ROOT="$SCRIPT_DIR"
    ROOT_DIR="$CHECKOUT_ROOT/.kstack"
  fi
  LIB_DIR="$ROOT_DIR/lib"

  SKILLS_SRC="$SRC_ROOT/skills"

  if [ ! -d "$SKILLS_SRC" ]; then
    echo "No skills/ directory at $SKILLS_SRC" >&2
    exit 1
  fi

  SKILL_NAMES=""
  for d in "$SKILLS_SRC"/*/; do
    [ -f "${d}SKILL.md.tmpl" ] || continue
    d="${d%/}"
    SKILL_NAMES="$SKILL_NAMES ${d##*/}"
  done
  SKILL_NAMES="${SKILL_NAMES# }"

  if [ -z "$SKILL_NAMES" ]; then
    echo "No SKILL.md.tmpl files found under $SKILLS_SRC" >&2
    exit 1
  fi

  GLOBAL_FLAGS_PARTIAL="$SKILLS_SRC/_partials/global-flags.md"
  UPDATE_CHECK_PARTIAL="$SKILLS_SRC/_partials/update-check.md"
  for p in "$GLOBAL_FLAGS_PARTIAL" "$UPDATE_CHECK_PARTIAL"; do
    if [ ! -f "$p" ]; then
      echo "ERROR: missing partial: $p" >&2
      exit 1
    fi
  done

  mkdir -p "$ROOT_DIR/cache"
  copy_bin "$SRC_ROOT/bin" "$ROOT_DIR/bin"
  copy_lib "$SRC_ROOT/lib" "$LIB_DIR"

  if [ "$GLOBAL" -eq 1 ]; then
    log "Installing kstack (global) for:$(printf ' %s' $TARGET_AGENTS)"
    # install.conf is written by ensure_src_checkout.
    for h in $TARGET_AGENTS; do
      install_agent global "$h" "$ROOT_DIR" \
        "$(agent_skills_dir_global "$h")" "kstack-"
    done
  else
    log "Installing kstack (local) for:$(printf ' %s' $TARGET_AGENTS)"
    write_local_install_conf "$ROOT_DIR" "$CHECKOUT_ROOT"
    for h in $TARGET_AGENTS; do
      install_agent local "$h" "$ROOT_DIR" \
        "$(agent_skills_dir_local "$CHECKOUT_ROOT" "$h")" ""
    done
  fi

  log ""
  log "kstack installed. Start a session with your agent to use the skills."
  if [ "$GLOBAL" -eq 1 ]; then
    log "To upgrade:   $ROOT_DIR/bin/upgrade"
    log "To uninstall: $ROOT_DIR/bin/uninstall"
  else
    log "To upgrade:   git pull && ./install  (or $ROOT_DIR/bin/upgrade)"
    log "To uninstall: delete this kstack repo directory."
  fi
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
