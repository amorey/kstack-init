# kstack uninstall — remove a global or local kstack install.
#
# Reads $ROOT_DIR/installed-skills (written by scripts/install) to determine
# which slot dirs belong to kstack. Every slot listed there is deleted from
# every target agent's skills_dir; the config/install root is removed last.
# User-authored skills in the same skills_dir are never touched because they
# never appear in the manifest.
#
# Detects which install it's bundled in from $SCRIPT_DIR:
#
#   Global: ~/.config/kstack/bin/uninstall — removes ~/.config/kstack and
#           every ~/.<agent>/skills/<slot>/ listed in installed-skills.
#   Local:  <project>/.kstack/bin/uninstall — removes <project>/.kstack and
#           every <project>/.<agent>/skills/<slot>/ listed in installed-skills.
#
# To remove a dev install (contributor layout), just delete the kstack
# repo directory — the dev install renders skills directly into
# <repo>/.<agent>/skills/ and never writes outside the repo.
#
# Usage:
#   uninstall              Interactive — prompts before removing.
#   uninstall --force      Skip the confirmation prompt.
#   uninstall --agent <n>  Scope to one agent.
#
# Uses `set -uo pipefail` (no -e) so uninstall never aborts partway.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/agents.sh
. "$SCRIPT_DIR/../lib/agents.sh"
# shellcheck source=../lib/manifest.sh
. "$SCRIPT_DIR/../lib/manifest.sh"

main() {
  if [ -z "${HOME:-}" ]; then
    echo "ERROR: \$HOME is not set" >&2
    exit 1
  fi

  local KSTACK_CONFIG_DIR="$HOME/.config/kstack"
  local ROOT_DIR
  ROOT_DIR="$(dirname "$SCRIPT_DIR")"

  local MODE PROJECT_DIR=""
  if [ "$ROOT_DIR" = "$KSTACK_CONFIG_DIR" ]; then
    MODE=global
  elif [ -d "$ROOT_DIR/upstream/.git" ]; then
    MODE=local
    PROJECT_DIR="$(dirname "$ROOT_DIR")"
  else
    echo "This uninstaller must be run from its bundled install location:" >&2
    echo "  global: $KSTACK_CONFIG_DIR/bin/uninstall" >&2
    echo "  local:  <project>/.kstack/bin/uninstall" >&2
    echo >&2
    echo "To remove a dev install, just delete the kstack repo directory." >&2
    exit 1
  fi

  local FORCE=0 AGENT=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) FORCE=1; shift ;;
      --agent)
        [ -z "${2:-}" ] && { echo "Missing value for --agent" >&2; exit 1; }
        AGENT="$2"; shift 2 ;;
      --agent=*) AGENT="${1#--agent=}"; shift ;;
      -h|--help)
        sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
        exit 0 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local TARGET_AGENTS
  if [ -z "$AGENT" ]; then
    TARGET_AGENTS="$KNOWN_AGENTS"
  elif is_known_agent "$AGENT"; then
    TARGET_AGENTS="$AGENT"
  else
    echo "Unknown agent: $AGENT" >&2
    echo "Supported: $KNOWN_AGENTS" >&2
    exit 1
  fi

  # The installed-skills manifest is our ownership marker — user-authored
  # skills in the same skills_dir are never touched because they don't appear
  # in it.
  local SLOTS=() slot
  while IFS= read -r slot; do
    [ -n "$slot" ] && SLOTS+=("$slot")
  done < <(manifest::read "$ROOT_DIR")

  local ENTRIES=() skills_dir h entry
  for h in $TARGET_AGENTS; do
    if [ "$MODE" = global ]; then
      skills_dir="$(agent_skills_dir_global "$h")"
    else
      skills_dir="$(agent_skills_dir_local "$PROJECT_DIR" "$h")"
    fi
    [ -d "$skills_dir" ] || continue
    # Guard: bash 3.2 (macOS default) treats "${SLOTS[@]}" on an empty array
    # as unbound under `set -u`.
    [ ${#SLOTS[@]} -eq 0 ] && continue
    for slot in "${SLOTS[@]}"; do
      entry="$skills_dir/$slot"
      [ -e "$entry" ] || [ -L "$entry" ] || continue
      ENTRIES+=("$entry")
    done
  done
  [ -d "$ROOT_DIR" ] && ENTRIES+=("$ROOT_DIR")

  if [ ${#ENTRIES[@]} -eq 0 ]; then
    echo "Nothing to remove — kstack is not installed."
    exit 0
  fi

  if [ "$FORCE" -eq 0 ]; then
    echo "This will remove:"
    printf '  %s\n' "${ENTRIES[@]}"
    printf "\nContinue? [y/N] "
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi

  local removed=""
  for entry in "${ENTRIES[@]}"; do
    rm -rf "$entry"
    removed="$removed ${entry#$HOME/}"
  done

  echo "Removed:$removed"
  echo "kstack uninstalled."
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
