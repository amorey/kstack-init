# kstack check-update — direct CLI for the cached update check.
#
# Usage:
#   check-update              Print notice, or "up to date" when no notice is due.
#   check-update --quiet      Print only if a notice is due; silent otherwise.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/cache.sh
. "$SCRIPT_DIR/../lib/cache.sh"
# shellcheck source=../lib/update-check.sh
. "$SCRIPT_DIR/../lib/update-check.sh"

main() {
  local QUIET=0
  case "${1:-}" in
    --quiet|-q) QUIET=1 ;;
  esac

  uc_notice "$SCRIPT_DIR"

  if [ -n "$NOTICE" ]; then
    echo "$NOTICE"
    exit 0
  fi

  [ "$QUIET" -eq 1 ] && exit 0
  [ -z "$INSTALLED" ] && exit 0

  # shellcheck disable=SC2154  # cache_* vars are populated by uc_notice.
  if [ -n "$cache_dismissed" ] && ! uc_is_newer "$cache_latest" "$cache_dismissed" \
     && uc_is_newer "$cache_latest" "$INSTALLED"; then
    echo "kstack $INSTALLED is up to date (update to $cache_latest dismissed)."
  else
    echo "kstack $INSTALLED is up to date."
  fi
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
