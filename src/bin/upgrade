# kstack upgrade — re-run install at the latest tag against the maintained
# upstream checkout bundled with this install. Only the two managed modes
# (global, local) are supported; dev installs upgrade via `git pull && ./install`
# and will fail here because $ROOT_DIR/upstream/ doesn't exist.

set -eu

main() {
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  ROOT_DIR="$(dirname "$SCRIPT_DIR")"

  if [ "$ROOT_DIR" = "$HOME/.config/kstack" ]; then
    exec "$ROOT_DIR/upstream/install" --global "$@"
  fi
  # Local install: cd to the project dir so the installer's $PWD-based
  # ROOT_DIR resolution points back here.
  cd "$(dirname "$ROOT_DIR")"
  exec "$ROOT_DIR/upstream/install" --local "$@"
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
