# kstack upgrade — re-run install against the maintained checkout at the
# latest tag (global mode), or `git pull && ./install` (repo-local mode).
# Detects its mode from its own install location.

set -eu

main() {
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  ROOT_DIR="$(dirname "$SCRIPT_DIR")"

  if [ "$ROOT_DIR" = "$HOME/.config/kstack" ]; then
    exec "$ROOT_DIR/upstream/install" --global "$@"
  fi

  # Repo-local: ROOT_DIR is <repo>/.kstack; the checked-out source is one level up.
  REPO_ROOT="$(dirname "$ROOT_DIR")"
  cd "$REPO_ROOT"
  git pull --ff-only
  exec ./install "$@"
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
