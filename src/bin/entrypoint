# kstack entrypoint — shared preamble invoked as the first tool call of every
# rendered SKILL.md. Exit-code contract and invocation signature live in
# src/skills/_partials/entrypoint.md (the canonical reference).

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/cache.sh
. "$SCRIPT_DIR/../lib/cache.sh"
# shellcheck source=../lib/update-check.sh
. "$SCRIPT_DIR/../lib/update-check.sh"

err() { printf '%s\n' "$*" >&2; }

# Fail-tolerant by design: any bug here must stay invisible to the calling skill.
run_update_check() {
  (
    uc_notice "$SCRIPT_DIR"
    [ -n "${NOTICE:-}" ] && printf '%s\n' "$NOTICE"
    exit 0
  ) 2>/dev/null || true
}

has_help_flag() {
  for a in "$@"; do
    case "$a" in
      --help|-h) return 0 ;;
    esac
  done
  return 1
}

main() {
  local skill_dir="" saw_sep=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --skill-dir=*)  skill_dir="${1#--skill-dir=}";  shift ;;
      --) saw_sep=1; shift; break ;;
      *)
        err "Unexpected flag before '--': $1"
        exit 11 ;;
    esac
  done

  if [ -z "$skill_dir" ]; then
    err "--skill-dir is required."
    exit 11
  fi
  if [ "$saw_sep" -eq 0 ]; then
    err "Missing '--' separator before user args."
    exit 11
  fi

  local skill_name
  skill_name="$(basename "$skill_dir")"

  # --help must short-circuit before the update check so the help output
  # stays clean (no notice prepended to the rendered help page).
  if has_help_flag "$@"; then
    local help_file="$skill_dir/references/help.md"
    if [ ! -f "$help_file" ]; then
      err "Help page missing for /$skill_name. Reinstall kstack."
      exit 11
    fi
    cat "$help_file"
    exit 0
  fi

  run_update_check

  local main_script="$skill_dir/scripts/main"
  if [ -e "$main_script" ]; then
    if [ ! -x "$main_script" ]; then
      err "Skill /$skill_name main script is not executable: $main_script"
      exit 11
    fi
    resolve_cache_paths "$SCRIPT_DIR"
    export KSTACK_ROOT="$ROOT_DIR"
    export KSTACK_SKILL_DIR="$skill_dir"
    export KSTACK_SKILL_NAME="$skill_name"
    exec "$main_script" "$@"
  fi

  exit 0
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
