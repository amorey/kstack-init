# kstack entrypoint — shared preamble invoked as the first tool call of every
# rendered SKILL.md. Always exits 0 and writes exactly one response envelope
# (schemas/response.schema.json) to stdout. The envelope and its agent-side
# contract are defined in src/skills/_partials/entrypoint.md.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/cache.sh
. "$SCRIPT_DIR/../lib/cache.sh"
# shellcheck source=../lib/update-check.sh
. "$SCRIPT_DIR/../lib/update-check.sh"
# shellcheck source=../lib/response.sh
. "$SCRIPT_DIR/../lib/response.sh"

# Fail-tolerant by design: any bug in the update check must stay invisible to
# the calling skill. Subshell isolates `set -u` failures; stdout capture lifts
# the notice into the caller.
compute_notice() {
  KSTACK_NOTICE="$(
    (
      uc_notice "$SCRIPT_DIR"
      [ -n "${NOTICE:-}" ] && printf '%s' "$NOTICE"
    ) 2>/dev/null || true
  )"
}

has_help_flag() {
  for a in "$@"; do
    case "$a" in
      --help|-h) return 0 ;;
    esac
  done
  return 1
}

main() {
  local skill_dir="" saw_sep=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --skill-dir=*)  skill_dir="${1#--skill-dir=}";  shift ;;
      --) saw_sep=1; shift; break ;;
      *)
        response::infra_error "Unexpected flag before '--': $1. Reinstall kstack."
        exit 0 ;;
    esac
  done

  if [ -z "$skill_dir" ]; then
    response::infra_error "--skill-dir is required. Reinstall kstack."
    exit 0
  fi
  if [ "$saw_sep" -eq 0 ]; then
    response::infra_error "Missing '--' separator before user args. Reinstall kstack."
    exit 0
  fi

  local skill_name
  skill_name="$(basename "$skill_dir")"

  # --help short-circuits before the update check so the notice is not glued
  # to the help page.
  if has_help_flag "$@"; then
    local help_file="$skill_dir/references/help.md"
    if [ ! -f "$help_file" ]; then
      response::infra_error "Help page missing for /$skill_name. Reinstall kstack."
      exit 0
    fi
    response::ok_verbatim "$(cat "$help_file")"
    exit 0
  fi

  compute_notice
  export KSTACK_NOTICE

  local main_script="$skill_dir/scripts/main"
  if [ -e "$main_script" ]; then
    if [ ! -x "$main_script" ]; then
      response::infra_error "Skill /$skill_name main script is not executable: $main_script. Reinstall kstack."
      exit 0
    fi
    resolve_cache_paths "$SCRIPT_DIR"
    export KSTACK_ROOT="$ROOT_DIR"
    export KSTACK_SKILL_DIR="$skill_dir"
    export KSTACK_SKILL_NAME="$skill_name"
    exec "$main_script" "$@"
  fi

  # No scripts/main — emit a preamble-only envelope so the agent continues
  # with the SKILL.md body (and surfaces any notice verbatim).
  response::ok_agent ""
  exit 0
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
