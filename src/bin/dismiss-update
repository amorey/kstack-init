# kstack dismiss-update — silence the current update notice until a newer release.
#
# Writes dismissed_version = latest_known in the local cache. The next time an
# upstream release bumps latest_known above the dismissed value, the notice
# returns automatically.
#
# Exits silently when there's nothing to dismiss (no cache, no known release).

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# shellcheck source=../lib/cache.sh
. "$SCRIPT_DIR/../lib/cache.sh"

main() {
  resolve_cache_paths "$SCRIPT_DIR"

  if [ ! -f "$CACHE_FILE" ]; then
    echo "Nothing to dismiss — no update check has run yet."
    exit 0
  fi

  # shellcheck disable=SC2034  # cache_dismissed is declared local so read_cache_fields doesn't leak to global scope.
  local cache_ts cache_latest cache_dismissed
  read_cache_fields "$CACHE_FILE"

  if [ -z "$cache_latest" ]; then
    echo "Nothing to dismiss — no known available release."
    exit 0
  fi

  write_cache_json "$CACHE_FILE" \
    "${cache_ts:-$(date -u +"%Y-%m-%dT%H:%M:%SZ")}" \
    "$cache_latest" \
    "$cache_latest"

  echo "Dismissed update notice for kstack $cache_latest. You'll be notified again when a newer release is published."
}

if [ "${BASH_SOURCE[0]:-$0}" = "$0" ]; then
  main "$@"
fi
