set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# Bootstrap before anything that could fail: we need response::* to emit
# any error envelope back to the agent.
if [ -z "${KSTACK_ROOT:-}" ]; then
  printf '{"kstack":"1","status":"error","kind":"infra","message":"KSTACK_ROOT not set; run this script via the skill entrypoint."}\n'
  exit 0
fi

# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/response.sh"
# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/kube-cache.sh"
# shellcheck source=lib/cluster-info.sh
. "$SCRIPT_DIR/lib/cluster-info.sh"
# shellcheck source=lib/node-info.sh
. "$SCRIPT_DIR/lib/node-info.sh"
# shellcheck source=lib/pod-info.sh
. "$SCRIPT_DIR/lib/pod-info.sh"

if [ -z "${KSTACK_KUBE_CONTEXT:-}" ]; then
  response::infra_error "KSTACK_KUBE_CONTEXT not set; run this script via the skill entrypoint."
  exit 0
fi

# wait_or_die <noun> <pid>
#   Wait on a backgrounded ensure_* job; on failure, emit infra error and exit 0.
wait_or_die() {
  local noun="$1" pid="$2"
  wait "$pid" && return 0
  # shellcheck disable=SC2016  # backticks render as inline code in markdown
  response::infra_error "$(printf 'Unable to fetch %s for context `%s`.' "$noun" "$KUBE_CACHE_CONTEXT")"
  exit 0
}

main() {
  local ttl="15m" refresh="false"
  while [ $# -gt 0 ]; do
    case "$1" in
      --refresh) refresh="true"; shift ;;
      --ttl=*) ttl="${1#--ttl=}"; shift ;;
      --ttl)
        if [ $# -lt 2 ]; then
          response::user_error "Flag --ttl requires a value."
          exit 0
        fi
        ttl="$2"; shift 2 ;;
      *)
        response::user_error "Unknown flag \`$1\`. Run \`/${KSTACK_SKILL_NAME:-cluster-status} --help\` for usage."
        exit 0 ;;
    esac
  done

  local init_args=(--ttl="$ttl")
  [ "$refresh" = "true" ] && init_args+=(--refresh)
  if ! kube_cache::init "${init_args[@]}"; then
    case "$KUBE_CACHE_ERROR_KIND" in
      user) response::user_error "$KUBE_CACHE_ERROR" ;;
      *)    response::infra_error "$KUBE_CACHE_ERROR" ;;
    esac
    exit 0
  fi

  local snapshot_start
  snapshot_start="$(date +%s)"

  # Fan the three independent fetches out in parallel — each writes a
  # different cache file via .tmp+mv, and KUBE_CACHE_* vars are read-only
  # after init, so there's no shared state to coordinate.
  local pid_v pid_n pid_p
  kube_cache::ensure_version &
  pid_v=$!
  kube_cache::ensure_list nodes &
  pid_n=$!
  kube_cache::ensure_list pods --all-namespaces &
  pid_p=$!
  wait_or_die 'cluster version' "$pid_v"
  wait_or_die 'nodes'           "$pid_n"
  wait_or_die 'pods'            "$pid_p"

  local err_tmp
  err_tmp="$(mktemp 2>/dev/null || echo "/tmp/kstack-cs-err-$$")"
  # shellcheck disable=SC2064  # expand err_tmp now so trap fires with the right value
  trap "rm -f '$err_tmp'" EXIT

  local content block
  if ! block="$(cluster_info::render "$KUBE_CACHE_CONTEXT" "$KUBE_CACHE_DIR/cluster.json" 2>"$err_tmp")"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi
  content="$block"
  content+=$'\n\n'

  if ! block="$(node_info::render "$KUBE_CACHE_DIR/nodes.json" 2>"$err_tmp")"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi
  content+="$block"
  content+=$'\n'

  if ! block="$(pod_info::render "$KUBE_CACHE_DIR/pods.json" 2>"$err_tmp")"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi
  content+="$block"

  # Any mtime predating $snapshot_start means that file was reused from
  # cache rather than re-fetched. Oldest such mtime = staleness ceiling of
  # the aggregated summary.
  local now oldest_mt="" mt from_cache=false
  now="$(date +%s)"
  for f in cluster.json nodes.json pods.json; do
    mt="$(_kube_cache::mtime "$KUBE_CACHE_DIR/$f")" || continue
    [ -n "$mt" ] || continue
    if [ "$mt" -lt "$snapshot_start" ]; then
      from_cache=true
      if [ -z "$oldest_mt" ] || [ "$mt" -lt "$oldest_mt" ]; then
        oldest_mt="$mt"
      fi
    fi
  done

  local freshness
  if [ "$from_cache" = "true" ] && [ -n "$oldest_mt" ]; then
    freshness="Used cached snapshot ($(kube_cache::format_duration "$(( now - oldest_mt ))") old, --refresh to update)."
  else
    freshness="Snapshot cached (TTL $ttl)."
  fi
  # shellcheck disable=SC2016  # backticks render as inline code in markdown
  content+=$'\n\n'"$freshness"$' Ask to drill in — e.g. "list nodes", "list pods", "pods on <node>", "which nodes are tainted".'

  # agent_context: skill-specific follow-up metadata. Compact JSON so future
  # fields can be added without schema churn. Values are JSON-escaped inline
  # since we only carry short path/identifier strings.
  local dir_esc agent_ctx
  dir_esc="$(printf '%s' "$KUBE_CACHE_DIR" | response::_escape)"
  agent_ctx="$(printf '{"cache_dir":"%s"}' "$dir_esc")"

  response::ok_verbatim "$content" "$agent_ctx"
  exit 0
}

main "$@"
