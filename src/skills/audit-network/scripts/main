set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

if [ -z "${KSTACK_ROOT:-}" ]; then
  printf '{"kstack":"1","status":"error","kind":"infra","message":"KSTACK_ROOT not set; run this script via the skill entrypoint."}\n'
  exit 0
fi

# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/response.sh"
# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/kube-cache.sh"
# shellcheck source=lib/network-policies.sh
. "$SCRIPT_DIR/lib/network-policies.sh"
# shellcheck source=lib/services.sh
. "$SCRIPT_DIR/lib/services.sh"

if [ -z "${KSTACK_KUBE_CONTEXT:-}" ]; then
  response::infra_error "KSTACK_KUBE_CONTEXT not set; run this script via the skill entrypoint."
  exit 0
fi

# wait_or_die <noun> <pid>
wait_or_die() {
  local noun="$1" pid="$2"
  wait "$pid" && return 0
  # shellcheck disable=SC2016
  response::infra_error "$(printf 'Unable to fetch %s for context `%s`.' "$noun" "$KUBE_CACHE_CONTEXT")"
  exit 0
}

main() {
  local ttl="15m" refresh="false"
  while [ $# -gt 0 ]; do
    case "$1" in
      --refresh) refresh="true"; shift ;;
      --ttl=*) ttl="${1#--ttl=}"; shift ;;
      --ttl)
        if [ $# -lt 2 ]; then
          response::user_error "Flag --ttl requires a value."
          exit 0
        fi
        ttl="$2"; shift 2 ;;
      *)
        response::user_error "Unknown flag \`$1\`. Run \`/${KSTACK_SKILL_NAME:-audit-network} --help\` for usage."
        exit 0 ;;
    esac
  done

  local init_args=(--ttl="$ttl")
  [ "$refresh" = "true" ] && init_args+=(--refresh)
  if ! kube_cache::init "${init_args[@]}"; then
    case "$KUBE_CACHE_ERROR_KIND" in
      user) response::user_error "$KUBE_CACHE_ERROR" ;;
      *)    response::infra_error "$KUBE_CACHE_ERROR" ;;
    esac
    exit 0
  fi

  # Fan out independent resource fetches in parallel.
  local pid_ns pid_np pid_svc pid_ep pid_pod
  kube_cache::ensure_list namespaces &
  pid_ns=$!
  kube_cache::ensure_list networkpolicies --all-namespaces &
  pid_np=$!
  kube_cache::ensure_list services --all-namespaces &
  pid_svc=$!
  kube_cache::ensure_list endpoints --all-namespaces &
  pid_ep=$!
  kube_cache::ensure_list pods --all-namespaces &
  pid_pod=$!

  wait_or_die 'namespaces'       "$pid_ns"
  wait_or_die 'networkpolicies'  "$pid_np"
  wait_or_die 'services'         "$pid_svc"
  wait_or_die 'endpoints'        "$pid_ep"
  wait_or_die 'pods'             "$pid_pod"

  local err_tmp
  err_tmp="$(mktemp 2>/dev/null || echo "/tmp/kstack-an-err-$$")"
  # shellcheck disable=SC2064
  trap "rm -f '$err_tmp'" EXIT

  # --- Workflow 1: Network Policies ---
  local netpol_block
  if ! netpol_block="$(network_policies::render "$KUBE_CACHE_DIR" 2>"$err_tmp")"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi

  # --- Workflow 2: Services ---
  local svc_block
  if ! svc_block="$(services::render "$KUBE_CACHE_DIR" 2>"$err_tmp")"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi

  # --- Assemble output ---
  local content
  content="Network Policies:"$'\n'"$netpol_block"$'\n\n'"Services:"$'\n'"$svc_block"

  local dir_esc ctx_esc agent_ctx
  dir_esc="$(printf '%s' "$KUBE_CACHE_DIR" | response::_escape)"
  ctx_esc="$(printf '%s' "$KUBE_CACHE_CONTEXT" | response::_escape)"
  agent_ctx="$(printf '{"cache_dir":"%s","context":"%s"}' "$dir_esc" "$ctx_esc")"

  response::ok_verbatim "$content" "$agent_ctx"
  exit 0
}

main "$@"
